---
interface Props {
  year: string;
  title: string;
  lang?: string;
}

const { year, title, lang = 'it-IT' } = Astro.props;
import "@styles/global.css";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={`${title} - DevFest Modena`} />
    <meta name="keywords" content="devfest, modena, google, developers, conference" />
    <meta name="author" content="GDG Modena" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <!-- <img src={`/assets/${year}/logo.svg`} alt={title} /> -->
      <h1>{title}</h1>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>
